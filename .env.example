# Expo / mobile client
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (set via `supabase secrets set`, never commit)
# ---------------------------------------------------------------------------
# SEND_SMS_HOOK_SECRET=v1,whsec_...          # Auth > Hooks > Send SMS
# UNISMS_API_SECRET_KEY=your-api-secret-key    # UniSMS docs: Basic auth username (password empty)
# UNISMS_SENDER_ID=                            # Optional custom sender ID (business accounts only)

# complete-registration + verify-login use built-in Supabase env:
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# ---------------------------------------------------------------------------
# Supabase Dashboard — REQUIRED security settings (see SECURITY.md)
# ---------------------------------------------------------------------------
# 1. Authentication > Rate Limits
#    - Limit phone OTP sends per hour (e.g. 5–10). Client cooldown alone is NOT enough.
#    - Enable CAPTCHA on OTP if your plan supports it.
#
# 2. Authentication > Hooks > Send SMS
#    - Hook URL: https://<project-ref>.supabase.co/functions/v1/unisms-hook
#    - Copy hook secret → supabase secrets set SEND_SMS_HOOK_SECRET="..."
#
# 3. After code changes:
#    supabase db push
#    supabase functions deploy unisms-hook complete-registration verify-login
